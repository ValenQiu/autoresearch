  "status": "active",

  "goal": "构建 SOTA 级别的通用 sim2sim & sim2real 人形机器人运控部署工具",

  "project_context": {
    "robot": "Unitree G1 29DoF",
    "framework": "独立新项目 (universal_humanoid_controller)",
    "architecture": "Python + onnxruntime + Unitree SDK2 DDS",
    "environments": ["conda (开发/真机)", "Docker (隔离/CI)"],
    "code_sources": {
      "asap_sim2real": {
        "path": "/home/qiulm/sources/ASAP/sim2real",
        "usage": "复制核心模块并重构，不直接依赖"
      },
      "motion_tracking_controller": {
        "path": "/home/qiulm/sources/motion_tracking_controller",
        "usage": "仅参考 BeyondMimic 观测拼接逻辑，不复用框架"
      }
    },
    "model_sources": ["本地 ONNX 文件", "WandB run path 自动下载"]
  },

  "state_machine": {
    "states": ["PASSIVE", "BASE_ACTIVE", "TASK_ACTIVE", "E_STOP"],
    "transitions": [
      {"from": "PASSIVE", "to": "BASE_ACTIVE", "trigger": "[i] init interpolation"},
      {"from": "BASE_ACTIVE", "to": "TASK_ACTIVE", "trigger": "[]] activate task", "guard": "base_stable"},
      {"from": "TASK_ACTIVE", "to": "BASE_ACTIVE", "trigger": "[[] switch back / auto-return / fault"},
      {"from": "*", "to": "E_STOP", "trigger": "[o] emergency stop"},
      {"from": "E_STOP", "to": "PASSIVE", "trigger": "[i] manual reset"}
    ]
  },

  "milestones": [
